# Copy this file to .env and fill in your values.
# cp env.example .env

# Required: OpenAI API key (used by openai-agents SDK and MCP tool calls)
OPENAI_API_KEY=

# Optional: OpenAI org and project (if using team/org APIs)
# OPENAI_ORG_ID=
# OPENAI_PROJECT_ID=

# Optional: Custom API base URL (e.g. Azure or proxy)
# OPENAI_BASE_URL=
